# Server
PORT=3000
ENV=dev
DEV_HOST=localhost
DEV_URL=http://localhost:3000
PROD_URL=https://api.acepick.com

# Database (used by Prisma)
DATABASE_URL=postgresql://acepick:acepick@localhost:5432/acepick
DB_NAME=acepick
DB_USER=acepick
DB_PASSWORD=acepick
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_INSTANCE_URL=

# JWT
TOKEN_SECRET=your-jwt-secret-here

# Email (SMTP)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_FROM=your-email@gmail.com
EMAIL_PASS=your-app-password

# SMS
SMS_API_KEY=
SMS_SENDER_ID=

# OTP
OTP_EXPIRY_TIME=5

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=

# Paystack
PAYSTACK_SECRET_KEY=

# Crypto
CRYPTO_SECRET_KEY=
CRYPTO_IV=
