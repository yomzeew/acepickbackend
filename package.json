{
  "name": "acepickapi",
  "version": "1.0.0",
  "description": "A connection platform for artisans and client",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npm run build && node ./build/app.js",
    "build": "tsc --project ./",
    "start": "node ./build/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:seed-smart": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-smart.ts",
    "cleanup:orders": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/cleanupOrders.ts",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:migrate": "docker compose exec api npx prisma migrate deploy",
    "docker:seed": "docker compose exec api npx prisma db seed"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-massive.ts"
  },
  "author": "Awar Abraham",
  "license": "ISC",
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "@faker-js/faker": "^10.0.0",
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.99.2",
    "@types/bcrypt": "^6.0.0",
    "acepickapi": "file:",
    "amqplib": "^0.10.5",
    "axios": "^1.8.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.0",
    "p-retry": "^6.2.1",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.1.2",
    "response-time": "^2.3.4",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.8.1",
    "stream-chat": "^8.56.1",
    "string-similarity": "^4.0.4",
    "twilio": "^5.13.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.15",
    "@types/response-time": "^2.3.9",
    "@types/string-similarity": "^4.0.2",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
